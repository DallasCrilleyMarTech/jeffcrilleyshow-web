---
interface Props {
  chapters: { time: string; title: string }[];
  youtubeId?: string;
}
const { chapters, youtubeId } = Astro.props;
function timeToSeconds(time: string): number {
  const parts = time.split(':').map(Number);
  if (parts.length === 3) return parts[0] * 3600 + parts[1] * 60 + parts[2];
  if (parts.length === 2) return parts[0] * 60 + parts[1];
  return 0;
}
---
{chapters.length > 0 && (
  <section>
    <h2 class="text-lg font-semibold mb-4">Chapters</h2>
    <div class="space-y-2">
      {chapters.map(({ time, title }) => {
        const seconds = timeToSeconds(time);
        const href = youtubeId ? `https://www.youtube.com/watch?v=${youtubeId}&t=${seconds}s` : undefined;
        return (
          <div class="flex items-baseline gap-3 group">
            {href ? (
              <a href={href} target="_blank" rel="noopener noreferrer"
                class="font-mono text-sm text-red-400 hover:text-red-300 transition-colors shrink-0">
                {time}
              </a>
            ) : (
              <span class="font-mono text-sm text-gray-500 shrink-0">{time}</span>
            )}
            <span class="text-gray-300 group-hover:text-white transition-colors">{title}</span>
          </div>
        );
      })}
    </div>
  </section>
)}
