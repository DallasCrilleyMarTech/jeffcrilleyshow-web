---
interface Props {
  guestName?: string;
  guestTitle?: string;
  publishDate: Date;
}
const { guestName, guestTitle, publishDate } = Astro.props;
const formattedDate = publishDate.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---
<div class="flex items-center gap-2 text-gray-400 text-sm flex-wrap">
  {guestName && <span class="text-white font-medium">{guestName}</span>}
  {guestName && guestTitle && <span>&middot;</span>}
  {guestTitle && <span>{guestTitle}</span>}
  {(guestName || guestTitle) && <span>&middot;</span>}
  <time datetime={publishDate.toISOString()}>{formattedDate}</time>
</div>
