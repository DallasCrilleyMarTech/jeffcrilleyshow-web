---
interface Props {
  socialLinks?: { facebook?: string; linkedin?: string; x?: string };
}
const { socialLinks } = Astro.props;
const links = [
  { platform: 'Facebook', url: socialLinks?.facebook },
  { platform: 'LinkedIn', url: socialLinks?.linkedin },
  { platform: 'X', url: socialLinks?.x },
].filter((l) => l.url);
---
{links.length > 0 && (
  <section>
    <h2 class="text-lg font-semibold mb-4">Follow This Episode</h2>
    <div class="flex gap-3">
      {links.map(({ platform, url }) => (
        <a href={url} target="_blank" rel="noopener noreferrer"
          class="px-4 py-2 text-sm font-medium rounded-lg bg-gray-800 text-gray-300 border border-gray-700 hover:border-gray-500 hover:text-white transition-all">
          {platform}
        </a>
      ))}
    </div>
  </section>
)}
